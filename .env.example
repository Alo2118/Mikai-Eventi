VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web Push (opzionale) — chiave VAPID PUBBLICA per l'attivazione push dal browser.
# Senza questa chiave la sezione "Notifiche push" resta inerte/nascosta.
# Genera la coppia con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Supabase CLI (per db push/pull — non usate dall'app)
SUPABASE_ACCESS_TOKEN=your-access-token
SUPABASE_DB_PASSWORD=your-database-password
